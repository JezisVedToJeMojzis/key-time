# Copy to .env and fill in. Generate VAPID keys with: npm run gen-vapid

# Web Push (VAPID) keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact address sent to the push service (mailto: or https:)
VAPID_SUBJECT=mailto:you@example.com

# Server
PORT=3000

# Persistence:
#   - Leave DATABASE_URL blank for local dev → records are stored in data/records.json
#   - Set it to a Postgres connection string (e.g. Neon) in production → records persist
#     across restarts. Required on hosts with an ephemeral filesystem (Render free tier).
DATABASE_URL=

# Secret required to call POST /api/tick from an external cron (e.g. cron-job.org).
# Leave blank to disable the protection (fine for local dev).
TICK_SECRET=
